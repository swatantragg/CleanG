# ============================================================
# G-Cleanser backend environment
# Copy to .env and fill in the blanks.
# ============================================================

# --- HTTP ---
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
HOST=0.0.0.0
PORT=8000

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
# Optional: full SQLAlchemy URL override (wins over POSTGRES_* above)
# e.g. postgresql://user:pass@host:5432/dbname  (driver is normalized automatically)
DATABASE_URL=

# --- Auth (JWT + argon2) ---
# REQUIRED: a long random secret. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=
ACCESS_TOKEN_TTL_MINUTES=720

# --- Storage ---
# Source files are stored as raw bytes in Postgres.
# STORAGE_BACKEND: "local" keeps the cleaned output in Postgres too (no creds needed);
# "drive" uploads the cleaned output to Google Drive (needs the GOOGLE_* vars below).
STORAGE_BACKEND=local
PUBLIC_BASE_URL=http://localhost:8000
SIGNED_URL_TTL_SECONDS=300
MAX_UPLOAD_BYTES=20971520
BRANCH_TTL_DAYS=7

# --- Google Drive (used only when STORAGE_BACKEND=drive) ---
# NOTE: a bare service account has NO Drive quota. The folder below MUST live inside a
# Shared Drive with the service account added as a member, OR set GOOGLE_DRIVE_IMPERSONATE_SUBJECT
# to a Workspace user (domain-wide delegation). A plain "My Drive" folder fails every upload
# with HTTP 403 storageQuotaExceeded.
# Path to the service-account JSON key file (e.g. ./secrets/drive-service-account.json).
GOOGLE_APPLICATION_CREDENTIALS=
# Drive folder id (inside a Shared Drive) the cleaned files are created under.
GOOGLE_DRIVE_FOLDER_ID=
# Optional Workspace user to impersonate via domain-wide delegation (alternative to a Shared Drive).
GOOGLE_DRIVE_IMPERSONATE_SUBJECT=
